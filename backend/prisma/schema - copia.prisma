// prisma/schema.prisma

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id                    Int            @id @default(autoincrement())
  nombre                String
  apellido              String
  cargo                 String
  jefe_directo          String?
  area_id               Int?
  email                 String         @unique
  password              String
  is_admin              Boolean        @default(false)
  
  // Permisos de Tareas
  can_create_tasks      Boolean        @default(false)
  can_edit_tasks        Boolean        @default(false)
  can_delete_tasks      Boolean        @default(false)
  
  // Permisos de Supervisión
  acceso_supervision    Boolean        @default(false)
  areas_autorizadas     String?        // Almacenado como string separado por comas (ej: "1,2,5")
  
  // Permisos de Módulos
  perm_users_view       Boolean        @default(false)
  perm_users_create     Boolean        @default(false)
  perm_users_edit       Boolean        @default(false)
  perm_users_delete     Boolean        @default(false)
  
  perm_areas_view       Boolean        @default(false)
  perm_areas_create     Boolean        @default(false)
  perm_areas_edit       Boolean        @default(false)
  perm_areas_delete     Boolean        @default(false)
  
  // Relaciones
  area                  Area?          @relation("AreaUsers", fields: [area_id], references: [id])
  managedAreas          Area[]         @relation("AreaManager") // <-- Corrección aplicada
  createdTasks          Task[]         @relation("CreatedTasks")
  notifications         Notification[]
  auditLogs             AuditLog[]
  comments              Comment[]
}

model Area {
  id              Int     @id @default(autoincrement())
  nombre          String
  descripcion     String?
  jefe_id         Int?    // <-- Corrección aplicada (sin @unique)
  parent_area_id  Int?
  
  // Relaciones
  jefe            User?   @relation("AreaManager", fields: [jefe_id], references: [id])
  parentArea      Area?   @relation("AreaHierarchy", fields: [parent_area_id], references: [id])
  subAreas        Area[]  @relation("AreaHierarchy")
  users           User[]  @relation("AreaUsers")
}

model Task {
  id                Int          @id @default(autoincrement())
  actividad         String
  responsable       String
  fecha_registro    String
  fecha_inicio      String
  fecha_fin         String
  fecha_ejecucion   String?
  prioridad         String       // Formato: "0|Muy Alta"
  prerequisito      String?
  observacion       String?
  cliente           String?
  porcentaje_avance Int          @default(0)
  estado            String       @default("Pendiente")
  created_by_id     Int
  
  // Relaciones
  creator           User         @relation("CreatedTasks", fields: [created_by_id], references: [id])
  attachments       Attachment[]
  auditLogs         AuditLog[]
  comments          Comment[]
}

model Notification {
  id         Int      @id @default(autoincrement())
  user_id    Int
  message    String
  read       Boolean  @default(false)
  created_at DateTime @default(now())
  
  user       User     @relation(fields: [user_id], references: [id])
}

model Attachment {
  id          Int      @id @default(autoincrement())
  task_id     Int
  filename    String
  filepath    String
  uploaded_at DateTime @default(now())
  
  task        Task     @relation(fields: [task_id], references: [id])
}

model AuditLog {
  id         Int      @id @default(autoincrement())
  task_id    Int
  user_id    Int
  action     String
  details    String
  created_at DateTime @default(now())
  
  task       Task     @relation(fields: [task_id], references: [id])
  user       User     @relation(fields: [user_id], references: [id])
}

model Comment {
  id         Int      @id @default(autoincrement())
  task_id    Int
  user_id    Int
  content    String
  created_at DateTime @default(now())

  task       Task     @relation(fields: [task_id], references: [id])
  user       User     @relation(fields: [user_id], references: [id])
}